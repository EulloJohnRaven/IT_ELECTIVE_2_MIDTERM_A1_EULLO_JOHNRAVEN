<!-- ABOUT ME SECTION -->
<section id="about" class="py-5 bg-light rounded-4 my-5 px-4">
    <div class="container-fluid">
        <p class="text-primary fw-bold mb-1">ABOUT ME</p>
        <h2 class="mb-4 fw-bold">A little about me</h2>
        <div class="row g-5">
            <div class="col-lg-7">
