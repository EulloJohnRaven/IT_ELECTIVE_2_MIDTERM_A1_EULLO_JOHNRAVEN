@{
    ViewData["Title"] = "Contact";
}
<section class="py-5">
    <h2 class="fw-bold mb-4">Let's connect</h2>
    <div class="fs-5">
        <p><strong>Email:</strong> <a href="mailto:@ViewData["Email"]">@ViewData["Email"]</a></p>
        <p><strong>Mobile:</strong> @ViewData["Mobile"]</p>
        <p><strong>GitHub:</strong> <a href="https://@ViewData["GitHub"]" target="_blank">@ViewData["GitHub"]</a></p>
        <p><strong>LinkedIn:</strong> <a href="https://@ViewData["LinkedIn"]" target="_blank">@ViewData["LinkedIn"]</a></p>
    </div>
    <a href="#" class="btn btn-primary mt-3">Download Resume</a>
</section>