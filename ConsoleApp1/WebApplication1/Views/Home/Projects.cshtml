@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Projects";
}

<!-- PROJECTS SECTION -->
<section id="projects" class="py-5 bg-light rounded-4 my-5 px-4">
    <div class="container-fluid">
        <p class="text-primary fw-bold mb-1">PROJECTS</p>
        <h2 class="mb-4 fw-bold">Selected projects</h2>
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card h-100 shadow-sm border-0">
                    <img src="~/images/Enrollment.jpg" class="card-img-top" alt="Student Enrollment System project" style="height: 200px; object-fit: cover;" />
                    <div class="card-body d-flex flex-column p-4">
                        <h5 class="card-title fw-bold">Student Enrollment System</h5>
                        <p class="card-text">A desktop application designed to easily manage student registration, assessment, and payment information.</p>
                        <div class="mt-auto">
                            <p class="mb-3"><small class="text-muted"><strong>Technologies:</strong> VB.NET, Windows Forms, DataGridView</small></p>
                            <a href="#contact" class="btn btn-outline-primary w-100">View Details</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card h-100 shadow-sm border-0">
                    <img src="~/images/Enterprise.jpg" class="card-img-top" alt="Enterprise Network Design project" style="height: 200px; object-fit: cover;" />
                    <div class="card-body d-flex flex-column p-4">
                        <h5 class="card-title fw-bold">Enterprise Network Design</h5>
                        <p class="card-text">A multi-site network design connecting branch offices and a head office using static routing, VLANs, and dynamic routing.</p>
                        <div class="mt-auto">
                            <p class="mb-3"><small class="text-muted"><strong>Technologies:</strong> Cisco Packet Tracer, OSPF, VLSM, VLANs</small></p>
                            <a href="#contact" class="btn btn-outline-primary w-100">View Details</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card h-100 shadow-sm border-0">
                    <img src="~/images/BD.jpg" class="card-img-top" alt="Blood Donor Finder project" style="height: 200px; object-fit: cover;" />
                    <div class="card-body d-flex flex-column p-4">
                        <h5 class="card-title fw-bold">Blood Donor Finder</h5>
                        <p class="card-text">A proposed cloud-based application that safely helps connect blood donors with people who need compatible blood donations.</p>
                        <div class="mt-auto">
                            <p class="mb-3"><small class="text-muted"><strong>Technologies:</strong> Cloud Computing, AWS, Web Development</small></p>
                            <a href="#contact" class="btn btn-outline-primary w-100">View Details</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

