@{
    ViewData["Title"] = "Skills";
}

<section id="skills" class="py-5">
    <div class="container-fluid">
        <p class="text-primary fw-bold mb-1">SKILLS</p>
        <h2 class="mb-4 fw-bold">Technologies I work with</h2>
        <div class="row g-4">
            <div class="col-md-6 col-xl-3">
                <div class="card h-100 shadow-sm border-0 text-center p-3">
                    <div class="card-body">
                        <h1 class="text-primary mb-3">&lt;/&gt;</h1>
                        <h5 class="card-title fw-bold">Programming Languages</h5>
                        <p class="card-text text-muted">C#, Java, Python, and VB.NET.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="card h-100 shadow-sm border-0 text-center p-3">
                    <div class="card-body">
                        <h1 class="text-primary mb-3">💻</h1>
                        <h5 class="card-title fw-bold">Web Technologies</h5>
                        <p class="card-text text-muted">ASP.NET Core MVC, HTML5, CSS3, and Bootstrap 5.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="card h-100 shadow-sm border-0 text-center p-3">
                    <div class="card-body">
                        <h1 class="text-primary mb-3">🗄️</h1>
                        <h5 class="card-title fw-bold">Databases</h5>
                        <p class="card-text text-muted">Microsoft Access, SQL, MySQL, and database normalization.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="card h-100 shadow-sm border-0 text-center p-3">
                    <div class="card-body">
                        <h1 class="text-primary mb-3">⚙</h1>
                        <h5 class="card-title fw-bold">Development Tools</h5>
                        <p class="card-text text-muted">Visual Studio, Git, GitHub, and Cisco Packet Tracer.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
