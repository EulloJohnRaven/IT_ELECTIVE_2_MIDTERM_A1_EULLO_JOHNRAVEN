<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>@ViewData["Title"] - Portfolio</title>

		<!-- Bootstrap CSS -->
		<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
		<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

		<!-- Custom styling to ensure desktop sidebar works seamlessly -->
		<style>
			.sidebar-sticky {
			top: 0;
			height: 100vh;
			overflow-x: hidden;
			overflow-y: auto;
			}
		</style>
	</head>
	<body>

		<!-- Mobile Hamburger Navbar (Visible only on small screens) -->
		<header class="d-lg-none">
			<nav class="navbar navbar-dark bg-dark px-3 fixed-top">
				<a class="navbar-brand fw-bold" href="#">John Raven J. Eullo</a>
				<button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu" aria-controls="sidebarMenu">
					<span class="navbar-toggler-icon"></span>
				</button>
			</nav>
		</header>

		<div class="container-fluid">
			<div class="row">
				<!-- Responsive Bootstrap Sidebar Navigation -->
				<nav id="sidebarMenu" class="col-lg-3 col-xl-2 d-lg-block bg-light sidebar collapse offcanvas-lg offcanvas-start border-end" tabindex="-1">
					<div class="position-sticky pt-5 pt-lg-3 sidebar-sticky d-flex flex-column align-items-center text-center">

						<div class="mt-4 mb-3">
							<div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-2 shadow" style="width: 70px; height: 70px; font-size: 28px; font-weight: bold;">
								JR
							</div>
							<h5 class="fw-bold mt-2">John Raven J. Eullo</h5>
							<p class="text-muted mb-0">Student</p>
						</div>

						<hr class="w-75" />

					<ul class="nav flex-column w-100 text-start px-3 mt-2">
						<li class="nav-item mb-2">
							<a class="nav-link text-dark fw-semibold" asp-controller="Home" asp-action="Index">Home</a>
						</li>
						<li class="nav-item mb-2">
							<a class="nav-link text-dark fw-semibold" asp-controller="Home" asp-action="About">About Me</a>
						</li>
						<li class="nav-item mb-2">
							<a class="nav-link text-dark fw-semibold" asp-controller="Home" asp-action="Skills">Skills</a>
						</li>
						<li class="nav-item mb-2">
							<a class="nav-link text-dark fw-semibold" asp-controller="Home" asp-action="Projects">Projects</a>
						</li>
						<li class="nav-item mb-2">
							<a class="nav-link text-dark fw-semibold" asp-controller="Home" asp-action="Contact">Contact</a>
						</li>
					</ul>
					</div>
				</nav>

				<!-- Main Content Area -->
				<main class="col-lg-9 ms-sm-auto col-xl-10 px-md-4 mt-5 mt-lg-0">
					@RenderBody()

					<footer class="mt-5 pb-4 text-center text-muted border-top pt-3">
						<p class="mb-0">&copy; 2026 John Raven J. Eullo. Built with ASP.NET Core MVC & Bootstrap 5.</p>
					</footer>
				</main>
			</div>
		</div>

		<!-- Bootstrap JS (Required for offcanvas/mobile menu) -->
		<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
		<script src="~/lib/jquery/dist/jquery.min.js"></script>
		<script src="~/js/site.js" asp-append-version="true"></script>
		@await RenderSectionAsync("Scripts", required: false)
	</body>
</html>